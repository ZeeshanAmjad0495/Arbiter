# ---------------------------------------------------------------------------
# Arbiter Phase 0 environment. Copy to `.env` and fill in.
# EVERY value here is optional: with none set, `pnpm hello` and `pnpm test`
# run fully offline (in-memory repos, regex sanitizer, stub LLM, no-op tracer).
# Set them to exercise the "real" path against docker-compose services.
# ---------------------------------------------------------------------------

# --- Runtime ---
NODE_ENV=development
ARBITER_LOG_LEVEL=info

# --- Postgres (audit + artifacts + projects/users). Provided by docker-compose. ---
# When unset, Arbiter uses an in-memory repository (data is not persisted).
DATABASE_URL=postgres://arbiter:arbiter@localhost:5442/arbiter

# --- Presidio PII/secret detection sidecar. Provided by docker-compose. ---
# When unset, Arbiter falls back to the built-in regex recognizers.
PRESIDIO_ANALYZER_URL=http://localhost:5002
PRESIDIO_ANONYMIZER_URL=http://localhost:5001

# --- De-masking store encryption key (32 bytes, base64). ---
# REQUIRED to persist placeholder<->real-value maps. `openssl rand -base64 32`.
# When unset, the de-masking store runs in ephemeral in-memory mode.
# With a DATABASE_URL set too, the vault persists (encrypted) to Postgres.
ARBITER_DEMASK_KEY=

# --- Test execution runner. `offline` (default) = deterministic stub, no
# binaries. `real` spawns the actual Playwright/k6 binary (executes user test
# code — opt-in). For Playwright real mode: `npx playwright install chromium`.
ARBITER_RUNNER=offline
ARBITER_RUNNER_TIMEOUT_MS=120000

# --- Dense retrieval. `local` embeds knowledge in-process with a free, offline
# model (all-MiniLM-L6-v2, 384-d) and searches pgvector; `off` (default) keeps
# TF-IDF. Needs the pgvector extension + migration 0010 when `local`. ---
ARBITER_EMBEDDINGS=off

# --- Anthropic (structured generation). When unset, the deterministic stub
# provider is used so the pipeline still runs end-to-end offline. ---
ANTHROPIC_API_KEY=
ARBITER_MODEL_DRAFT=claude-haiku-4-5-20251001
ARBITER_MODEL_DEFAULT=claude-sonnet-5
ARBITER_MODEL_JUDGE=claude-opus-4-8

# --- Kimi (Moonshot AI) — for testing. When KIMI_API_KEY is set it TAKES
# PRECEDENCE over Anthropic. Defaults to the latest thinking model (Kimi K2.6),
# OpenAI-compatible, with native reasoning enabled. ---
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k2.6
KIMI_THINKING=enabled

# --- Jira read-only fetch-by-ticket-key (grounding pull-forward). All three
# must be set to enable the "Fetch Jira" button. Read-only; never writes. ---
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# --- Confluence read-only fetch-by-page-id (grounding source). Read-only. ---
CONFLUENCE_BASE_URL=
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=

# --- GitHub — the first real WriteGate target (gated defect write-back). Writes
# ONLY to this repo, ONLY via the human-approved WriteGate. Never the connected
# Jira. When unset, the WriteGate uses the in-memory sandbox target. ---
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# --- Read-only observability ground sources — FREE/OSS only. Self-host with
# `docker compose -f docker-compose.observability.yml up -d`. Sentry connector is
# Sentry-API-compatible (works with the bundled GlitchTip). GET-only; sanitized. ---
# Sentry / GlitchTip: SENTRY_BASE_URL default https://sentry.io (self-host: http://localhost:8080)
SENTRY_BASE_URL=http://localhost:8080
SENTRY_ORG=
SENTRY_AUTH_TOKEN=
# Grafana (self-host: http://localhost:3001) + a Viewer service-account token
GRAFANA_URL=
GRAFANA_TOKEN=

# --- Telemetry (OpenTelemetry -> optional OTLP/Langfuse). When unset, spans
# are recorded to an in-process no-op/console tracer. ---
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=arbiter

# --- API server ---
ARBITER_API_PORT=4310
